# ignore build files, but include the pre-built JAR
target/
!target/openinghours-*.jar
build/

# ignore ide modeules
.idea/
*.iml
*.ipr
*.iws
*.sw?

# ignore Git
.git/
.gitignore

# ignore system files
.DS_Store
Thumbs.db

# ignore environment files
.env
*.log

# ignore tests
*.test.js
*.spec.js
__tests__/

# optional: ignore other files
*.tmp
*.bak
*.old
